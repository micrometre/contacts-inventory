    "predeploy": "npm run css:build-once"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8"
  }
}
