{
  "name": "contacts-inventory",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run css:build-once",
    "preview": "vite preview",
    "css:build": "tailwindcss -i ./src/input.css -o ./output.css --watch",
